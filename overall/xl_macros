Sub GroupAPIs()

    Dim ws As Worksheet
    Dim LastRow As Long
    Dim StartRow As Long
    Dim i As Long

    Set ws = ActiveSheet

    Rows.ClearOutline

    LastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row

    StartRow = 2

    For i = 3 To LastRow + 1

        If ws.Cells(i, 1).Value <> "" Or i = LastRow + 1 Then

            If i - StartRow > 1 Then
                ws.Rows(StartRow + 1 & ":" & i - 1).Group
            End If

            StartRow = i

        End If

    Next i

End Sub